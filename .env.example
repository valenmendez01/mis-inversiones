# ==========================================
# 1. CREDENCIALES DE LA BASE DE DATOS MASTER
# ==========================================
# Esta es la URL y el Token de tu base de datos PRINCIPAL (la que creas manualmente).
# Aquí SOLO se guardarán los usuarios, contraseñas, URLs y Tokens de los clientes.
TURSO_DATABASE_URL="libsql://master-db-tu-usuario.turso.io"
TURSO_AUTH_TOKEN="tu_token_secreto_de_la_master_db"

# ==========================================
# 2. SEGURIDAD DE LA APLICACIÓN (NEXT.JS)
# ==========================================
# Secreto para encriptar la cookie de sesión (JWT). 
# Generado con: openssl rand -base64 32
AUTH_SECRET="tu_hash_super_secreto_aqui"

# ==========================================
# 3. API DE ADMINISTRACIÓN DE TURSO
# ==========================================
# Credenciales para poder crear nuevas bases de datos automáticamente
# cuando alguien hace click en "Registrarse".

# Tu nombre de usuario en Turso (o el nombre de tu organización si creaste una)
TURSO_ORG_NAME="valenmendez01" 

# Token de la Plataforma Turso (Se genera en la terminal con: turso auth api-tokens mint)
# Ojo: Este NO es el token de una base de datos, es el token de tu CUENTA de Turso.
TURSO_API_TOKEN="tu_api_token_global_aqui"